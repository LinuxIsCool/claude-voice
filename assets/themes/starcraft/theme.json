{
  "meta": {
    "name": "StarCraft",
    "slug": "starcraft",
    "version": "1.0.0",
    "description": "Digital military command interface. Square waves, radio chirps, scanner sweeps.",
    "accent_color": "#00ff41",
    "greeting_template": "Commander, {summary}",
